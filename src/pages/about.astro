---
import Layout from '../components/Layout.astro';
---

<Layout title="About — Hoikei Chan" description="About me and this site">
  <section class="max-w-3xl mx-auto px-6 py-16">
    <h1 class="font-serif text-3xl font-extrabold text-[var(--color-text)] mb-8">About</h1>

    <div class="prose-custom prose prose-slate max-w-none space-y-6">
      <p class="text-lg text-[var(--color-text-secondary)] leading-relaxed">
        Hi, I'm Hoikei Chan, a medical student exploring the intersection of AI and medicine.
        This site is where I share research thoughts, track my progress, and collect clinical tools that help me learn.
      </p>

      <h2 class="font-serif text-xl font-bold text-[var(--color-text)] mt-10 mb-4">This Site</h2>
      <ul class="list-disc pl-5 text-[var(--color-text-secondary)] space-y-2">
        <li><strong>Thinking &amp; Notes</strong> — research thoughts, interesting findings, and what I learned</li>
        <li><strong>Achievements</strong> — my journey at the intersection of AI and medicine</li>
        <li><strong>Bedside Reference</strong> — clinical scales and assessment tools for ward rounds</li>
      </ul>

      <h2 class="font-serif text-xl font-bold text-[var(--color-text)] mt-10 mb-4">Contact</h2>
      <p class="text-[var(--color-text-secondary)]">
        GitHub: <a href="https://github.com/kyle-med" class="text-[var(--color-accent)] hover:text-[var(--color-accent-hover)]">@kyle-med</a><br />
        Email: <a href="mailto:23301050071@m.fudan.edu.cn" class="text-[var(--color-accent)] hover:text-[var(--color-accent-hover)]">23301050071@m.fudan.edu.cn</a>
      </p>
    </div>
  </section>
</Layout>
