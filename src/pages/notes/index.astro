---
import Layout from '../../components/Layout.astro';
import NoteCard from '../../components/NoteCard.astro';
import TagFilter from '../../components/TagFilter.astro';
import SearchBox from '../../components/SearchBox.astro';
import { getCollection } from 'astro:content';

const allNotes = (await getCollection('notes', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const allTags = [...new Set(allNotes.flatMap((n) => n.data.tags))].sort();
---

<Layout title="Thinking &amp; Notes — Hoikei Chan" description="Research thoughts, interesting findings, and what I learned">
  <section class="max-w-3xl mx-auto px-6 py-16">
    <h1 class="font-serif text-3xl font-extrabold text-[var(--color-text)] mb-2">Thinking &amp; Notes</h1>
    <p class="text-[var(--color-text-secondary)] mb-8">Interesting findings, strategies and what I learned</p>

    <SearchBox />
    <TagFilter tags={allTags} activeTag={null} gridId="notes-grid" />

    <div id="notes-grid" class="grid gap-4">
      {allNotes.map((note) => <NoteCard note={note} />)}
    </div>
  </section>
</Layout>
