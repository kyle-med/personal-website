---
import Layout from '../../components/Layout.astro';
import SearchBox from '../../components/SearchBox.astro';
import { scales, specialties } from '../../data/scales';
---

<Layout title="Bedside Reference — Hoikei Chan" description="A curated collection of essential medical scales for clinical rotations">
  <section class="max-w-3xl mx-auto px-6 py-16">
    <h1 class="font-serif text-3xl font-extrabold text-[var(--color-text)] mb-2">Bedside Reference</h1>
    <p class="text-sm font-medium text-[var(--color-accent)] mb-2">Your digital companion for clinical rotations</p>
    <p class="text-[var(--color-text-secondary)] mb-8">
      A curated collection of essential medical scales frequently used during ward rounds and clinical practice.
      Organized by specialty, this module ensures you have the most reliable assessment tools ready whenever you need them at the bedside.
    </p>

    <SearchBox />

    <div id="tag-filters" class="flex flex-wrap gap-2 mb-8">
      <button data-specialty="" class="tag-btn text-sm px-3 py-1 rounded-full border transition-colors bg-[var(--color-accent)] text-white border-[var(--color-accent)]">
        All
      </button>
      {specialties.map((sp) => (
        <button data-specialty={sp} class="tag-btn text-sm px-3 py-1 rounded-full border transition-colors bg-[var(--color-surface)] text-[var(--color-text-secondary)] border-[var(--color-border)] hover:border-[var(--color-accent)] hover:text-[var(--color-accent)]">
          {sp}
        </button>
      ))}
    </div>

    <div id="scales-grid" class="grid gap-4">
      {scales.map((scale) => (
        <a
          href={`/reference/${scale.slug}`}
          data-specialty={scale.specialty}
          class="scale-card block p-5 rounded-lg border border-[var(--color-border)] bg-[var(--color-surface)] hover:shadow-sm hover:-translate-y-0.5 transition-all"
        >
          <h3 class="font-serif font-bold text-[var(--color-text)] mb-1">{scale.title}</h3>
          <p class="text-sm text-[var(--color-text-secondary)] leading-relaxed line-clamp-2">{scale.description}</p>
          <span class="inline-block mt-3 text-xs px-2 py-0.5 rounded-full bg-[var(--color-bg)] border border-[var(--color-border)] text-[var(--color-text-secondary)]">
            {scale.specialty}
          </span>
        </a>
      ))}
    </div>
  </section>
</Layout>

<script is:inline>
  // Client-side tag filtering
  (function () {
    const buttons = document.querySelectorAll('#tag-filters .tag-btn');
    const cards = document.querySelectorAll('.scale-card');

    function filter(specialty) {
      cards.forEach((card) => {
        if (!specialty || card.dataset.specialty === specialty) {
          card.style.display = '';
        } else {
          card.style.display = 'none';
        }
      });

      buttons.forEach((btn) => {
        const isActive = btn.dataset.specialty === specialty;
        btn.className = isActive
          ? 'tag-btn text-sm px-3 py-1 rounded-full border transition-colors bg-[var(--color-accent)] text-white border-[var(--color-accent)]'
          : 'tag-btn text-sm px-3 py-1 rounded-full border transition-colors bg-[var(--color-surface)] text-[var(--color-text-secondary)] border-[var(--color-border)] hover:border-[var(--color-accent)] hover:text-[var(--color-accent)]';
      });

      // Update URL without page reload
      const url = new URL(window.location);
      if (specialty) {
        url.searchParams.set('specialty', specialty);
      } else {
        url.searchParams.delete('specialty');
      }
      window.history.replaceState({}, '', url);
    }

    buttons.forEach((btn) => {
      btn.addEventListener('click', () => {
        filter(btn.dataset.specialty || '');
      });
    });

    // Apply filter from URL on page load
    const params = new URLSearchParams(window.location.search);
    const active = params.get('specialty') || '';
    filter(active);
  })();
</script>
