<div class="pb-10">
  <header class="glass-header sticky top-0 z-40 px-6 py-4 border-b border-gray-200 text-center bg-white/80 backdrop-blur-xl">
    <h1 class="text-xl font-semibold text-gray-900">GCS 昏迷评分</h1>
  </header>

  <div id="gcs-app" class="max-w-md mx-auto">
    <div class="px-4 mt-6 space-y-8">
      <section>
        <h2 class="text-sm font-semibold text-gray-500 uppercase tracking-wider mb-3 px-2">睁眼反应 (Eye Opening)</h2>
        <div class="bg-white rounded-2xl overflow-hidden shadow-sm border border-gray-100">
          <label v-for="item in options.eye" :key="item.val" class="block">
            <input type="radio" v-model="scores.e" :value="item.val">
            <div :class="selectedClass(scores.e, item.val)">
              <span class="text-gray-800 font-medium" v-text="item.text"></span>
              <span :class="scoreClass(scores.e, item.val)" v-text="item.val + '分'"></span>
            </div>
          </label>
        </div>
      </section>

      <section>
        <h2 class="text-sm font-semibold text-gray-500 uppercase tracking-wider mb-3 px-2">语言反应 (Verbal Response)</h2>
        <div class="bg-white rounded-2xl overflow-hidden shadow-sm border border-gray-100">
          <label v-for="item in options.verbal" :key="item.val" class="block">
            <input type="radio" v-model="scores.v" :value="item.val">
            <div :class="selectedClass(scores.v, item.val)">
              <span class="text-gray-800 font-medium" v-text="item.text"></span>
              <span :class="scoreClass(scores.v, item.val)" v-text="item.val + '分'"></span>
            </div>
          </label>
        </div>
      </section>

      <section>
        <h2 class="text-sm font-semibold text-gray-500 uppercase tracking-wider mb-3 px-2">运动反应 (Motor Response)</h2>
        <div class="bg-white rounded-2xl overflow-hidden shadow-sm border border-gray-100">
          <label v-for="item in options.motor" :key="item.val" class="block">
            <input type="radio" v-model="scores.m" :value="item.val">
            <div :class="selectedClass(scores.m, item.val)">
              <span class="text-gray-800 font-medium" v-text="item.text"></span>
              <span :class="scoreClass(scores.m, item.val)" v-text="item.val + '分'"></span>
            </div>
          </label>
        </div>
      </section>

      <div :class="scoreColor">
        <div class="text-sm opacity-80 mb-1 font-medium italic">GCS Total Score</div>
        <div class="text-6xl font-bold mb-4" v-text="totalScore"></div>
        <div class="text-lg font-semibold" v-text="'E' + scores.e + ' V' + scores.v + ' M' + scores.m"></div>
        <div v-if="totalScore &lt;= 8" class="mt-4 py-2 px-4 bg-white/20 rounded-full inline-block animate-pulse">
          ⚠️ 提示：需气管插管
        </div>
      </div>
    </div>
  </div>
</div>
