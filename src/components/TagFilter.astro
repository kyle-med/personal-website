---
const { tags, gridId } = Astro.props as { tags: string[]; activeTag: string | null; gridId: string };

const filterId = gridId + '-tagfilter';
---

<div id={filterId} class="flex flex-wrap gap-2 mb-6">
  <button data-tag="" class="filter-btn text-sm px-3 py-1 rounded-full border cursor-pointer transition-colors" style="background:var(--color-accent);color:#fff;border-color:var(--color-accent)">
    All
  </button>
  {tags.map((tag) => (
    <button data-tag={tag} class="filter-btn text-sm px-3 py-1 rounded-full border cursor-pointer transition-colors" style="background:var(--color-surface);color:var(--color-text-secondary);border-color:var(--color-border)">
      {tag}
    </button>
  ))}
</div>

<script define:vars={{ filterId, gridId }}>
  (function () {
    const FILTER_ID = filterId;
    const GRID_ID = gridId;

    const container = document.getElementById(FILTER_ID);
    if (!container) return;
    const buttons = container.querySelectorAll('.filter-btn');
    const grid = document.getElementById(GRID_ID);
    if (!grid) return;

    const ACTIVE_STYLE = 'background:var(--color-accent);color:#fff;border-color:var(--color-accent)';
    const INACTIVE_STYLE = 'background:var(--color-surface);color:var(--color-text-secondary);border-color:var(--color-border)';

    function filter(tag) {
      const cards = grid.querySelectorAll('[data-tags]');
      cards.forEach((card) => {
        if (!tag || (card.dataset.tags || '').split(',').includes(tag)) {
          card.style.display = '';
        } else {
          card.style.display = 'none';
        }
      });

      buttons.forEach((btn) => {
        btn.style.cssText = (btn.dataset.tag === tag ? ACTIVE_STYLE : INACTIVE_STYLE)
          + ';border-radius:9999px;padding:4px 12px;font-size:0.875rem;cursor:pointer';
      });

      var url = new URL(window.location);
      if (tag) { url.searchParams.set('tag', tag); }
      else { url.searchParams.delete('tag'); }
      window.history.replaceState({}, '', url);
    }

    buttons.forEach(function (btn) {
      btn.addEventListener('click', function () {
        filter(btn.getAttribute('data-tag') || '');
      });
    });

    var active = new URLSearchParams(window.location.search).get('tag') || '';
    filter(active);
  })();
</script>
