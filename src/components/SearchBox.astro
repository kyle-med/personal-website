---
// Custom Pagefind search box — supports Enter key and debounced typing
---
<div class="mb-6" id="search-container">
  <input
    id="search-input"
    type="text"
    placeholder="Search..."
    class="w-full px-4 py-2.5 rounded-lg border border-[var(--color-border)] bg-[var(--color-surface)] text-sm text-[var(--color-text)] font-sans focus:outline-none focus:ring-2 focus:ring-[var(--color-accent)] focus:ring-offset-0 transition-shadow"
    disabled
  />
</div>
<div id="search-results" class="grid gap-2"></div>

<script is:inline>
  (async () => {
    const input = document.getElementById('search-input');
    if (!input) return;

    let pagefind = null;
    let searchId = 0;

    try {
      pagefind = await import('/pagefind/pagefind.js');
      await pagefind.init();
      input.disabled = false;
      input.placeholder = 'Search...';
    } catch (e) {
      input.placeholder = 'Search available after build...';
      return;
    }

    const resultsEl = document.getElementById('search-results');

    function renderResults(results) {
      if (!resultsEl) return;
      if (!results || results.length === 0) {
        resultsEl.innerHTML = '';
        return;
      }
      resultsEl.innerHTML = results.map((r) => `
        <a href="${r.url}" class="block p-4 rounded-lg border border-[var(--color-border)] bg-[var(--color-surface)] hover:shadow-sm transition-all">
          <div class="font-medium text-sm text-[var(--color-text)]">${r.meta?.title || r.url}</div>
          <div class="text-xs text-[var(--color-text-secondary)] mt-1">${r.excerpt || ''}</div>
        </a>
      `).join('');
    }

    async function doSearch(query) {
      const id = ++searchId;
      if (!query.trim()) {
        renderResults([]);
        return;
      }
      const result = await pagefind.search(query);
      if (id !== searchId) return; // ignore stale results
      const data = await Promise.all(result.results.map((r) => r.data()));
      if (id !== searchId) return;
      renderResults(data);
    }

    // Debounced search while typing
    let debounceTimer;
    input.addEventListener('input', () => {
      clearTimeout(debounceTimer);
      debounceTimer = setTimeout(() => doSearch(input.value), 300);
    });

    // Enter triggers immediate search (with composition support for IME)
    input.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' && !e.isComposing) {
        e.preventDefault();
        clearTimeout(debounceTimer);
        doSearch(input.value);
      }
    });
  })();
</script>
